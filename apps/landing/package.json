{
  "name": "escribano-landing",
  "scripts": {

    "dev": "hugo server -D --navigateToChanged",
    "build": "hugo --gc --minify",
    "video:preview": "remotion studio remotion/src/index.ts",
    "video:render": "remotion render remotion/src/index.ts --audio-sample-rate=48000 --concurrency=1",
    "video:render:desktop": "pnpm video:render EscribanoAgentMemory static/video/escribano-agent-memory.mp4 --codec=h264 --crf=18",
    "video:render:mobile": "pnpm video:render EscribanoAgentMemoryMobile static/video/escribano-agent-memory-mobile.mp4 --codec=h264 --crf=18",
    "video:render:linkedin": "pnpm video:render EscribanoAgentMemoryLinkedIn static/video/escribano-agent-memory-linkedin.mp4 --codec=h264 --crf=18",
    "video:render:all": "pnpm video:render:desktop & pnpm video:render:mobile & pnpm video:render:linkedin"
  },
  "dependencies": {
    "@remotion/animation-utils": "4.0.454",
    "@remotion/cli": "^4.0.454",
    "@remotion/install-whisper-cpp": "4.0.454",
    "@remotion/media-utils": "^4.0.456",
    "@remotion/three": "4.0.454",
    "@remotion/transitions": "4.0.454",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remotion": "^4.0.454"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
